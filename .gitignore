# Nix
/result
/result-*
/.direnv
/.envrc
/.conversion-info
.DS_Store

# Editor / agent state
/.claude/

# Large build artifacts & caches — never commit (regenerated by the bootstrap)
/work/
/.tcc-darwin-archive-cache/
/.tcc-darwin-header-stamps/
bake/target/
bake/.tcc-darwin-archive-cache/
bake/.tcc-darwin-header-stamps/

# Stray generated headers leaked into the tree by build experiments.
# Canonical headers live under bootstrap/headers/, vendor/, M2libc/, etc.
/*.h
/bake/*.h

# Stray build/test outputs from running the chain in-tree
/a.out
/artest/
/cvttest/
/make-test/
/idC/
/idirB/
/subt/
/sys/
/gcc46-bootstrap.*
/bake/a.out
/bake/*.o
/bake/int128
/bake/int128.c
/bake/multi
/bake/multi-helper.c
/bake/multi-helper.o
/bake/multi-main.c
/bake/multi-main.o
/bake/smoke
/bake/smoke.c
/bake/smoke.o
/bake/artest/
/bake/cvttest/
/bake/make-test/
/bake/sys/
/bake/gcc46-bootstrap.*
/.tcc-darwin-cache/
bake/.tcc-darwin-cache/

# Nix
/result
/result-*
/.direnv
/.envrc
/.conversion-info
.DS_Store

# Editor / agent state
/.claude/

# Shell-track build state (regenerated by `sh build.sh`; tarballs are
# fetched by scripts/fetch-sources.sh against pinned SHA-256 hashes)
/target/
/tarballs/
/work/
/tmp/

# Nix-track scratch tree
/nix/work/

# tcc-darwin-cc caches: quote-include header materialization + archive cache
/.tcc-darwin-cache/
/.tcc-darwin-archive-cache/
/.tcc-darwin-header-stamps/

# Stray generated headers leaked into the tree by build experiments.
# Canonical headers live under nix/bootstrap/headers/, nix/vendor/,
# nix/M2libc/, etc.
/*.h

# Stray build/test outputs from running the chain in-tree
/a.out
/artest/
/cvttest/
/make-test/
/idC/
/idirB/
/subt/
/sys/
/gcc46-bootstrap.*
/int128
/int128.c
/multi
/multi-helper.c
/multi-helper.o
/multi-main.c
/multi-main.o
/smoke
/smoke.c
/smoke.o
/*.o

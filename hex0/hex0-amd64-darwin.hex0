00 00 00 00 01 00 00 00                         ## 0x0080: vmaddr = 0x100000000
00 10 00 00 00 00 00 00                         ## 0x0088: vmsize = one page
00 00 00 00 00 00 00 00                         ## 0x0090: fileoff = 0
00 10 00 00 00 00 00 00                         ## 0x0098: filesize = one page

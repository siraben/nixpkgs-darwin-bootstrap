00 00 00 00                                     ## 0x00e8: reloff = 0
00 00 00 00                                     ## 0x00ec: nreloc = 0
00 04 00 80                                     ## 0x00f0: flags = S_REGULAR | S_ATTR_PURE_INSTRUCTIONS | S_ATTR_SOME_INSTRUCTIONS
00 00 00 00                                     ## 0x00f4: reserved1 = 0
00 00 00 00                                     ## 0x00f8: reserved2 = 0
00 00 00 00                                     ## 0x00fc: reserved3 = 0


80 01 00 00                                     ## 0x0014: sizeofcmds = 0x180
85 00 00 00                                     ## 0x0018: MH_NOUNDEFS | MH_DYLDLINK | MH_TWOLEVEL
00 00 00 00                                     ## 0x001c: reserved


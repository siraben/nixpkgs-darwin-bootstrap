+  return r;
+}
+static void bootstrap_append_ulong(char *p, unsigned long value) {
+  char tmp[32];
+  int i;
+  int j;
+  if (value == 0) {
+    *p++ = '0';
+    *p = 0;
+    return;
+  }
+  i = 0;
+  while (value) {
+    tmp[i++] = '0' + (value % 10);
+    value = value / 10;
+  }
+  for (j = i - 1; j >= 0; j--) *p++ = tmp[j];
+  *p = 0;
+}
+char *choose_tmpdir(void) {
+  return bootstrap_copy("/tmp/");
+}
+char *make_temp_file(const char *suffix) {
+  const char *base = "/tmp/gcc-bootstrap-";
+  unsigned long base_len = strlen(base);
+  unsigned long suffix_len;
+  char digits[32];
+  char *name;
+  bootstrap_temp_counter++;
+  bootstrap_append_ulong(digits, bootstrap_temp_counter);
+  if (!suffix) suffix = "";
+  suffix_len = strlen(suffix);
+  name = (char *)malloc(base_len + strlen(digits) + suffix_len + 1);
+  if (!name) return 0;
+  strcpy(name, base);
+  strcat(name, digits);
+  strcat(name, suffix);
+  return name;

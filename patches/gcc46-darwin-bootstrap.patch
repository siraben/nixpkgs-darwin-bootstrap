+  value = strchr(arg, '=');
+  name_len = value ? (unsigned long)(value - arg) : strlen(arg);
+  for (i = 0; long_options[i].name; i++) {
+    if (strlen(long_options[i].name) == name_len && !strncmp(arg, long_options[i].name, name_len)) {
+      if (opt_index) *opt_index = i;
+      if (long_options[i].has_arg) {
+        if (value) optarg = (char *)value + 1;
+        else if (optind < 0) optarg = 0;
+      }
+      if (long_options[i].flag) {
+        *long_options[i].flag = long_options[i].val;
+        return 0;
+      }
+      return long_options[i].val;
+    }
+  }
+  return '?';

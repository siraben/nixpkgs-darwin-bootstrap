+static void bootstrap_append_ulong(char *p, unsigned long value) {
+  char tmp[32];
+  int i;
+  int j;
+  if (value == 0) {
+    *p++ = '0';
+    *p = 0;
+    return;
+  }
+  i = 0;
+  while (value) {
+    tmp[i++] = '0' + (value % 10);
+    value = value / 10;
+  }

+  arg = argv[optind];
+  if (!arg || arg[0] != '-' || arg[1] == 0) return -1;
+  if (arg[1] == '-' && arg[2] == 0) {
+    optind++;
+    return -1;
+  }
+  optopt = arg[1];
+  spec = bootstrap_option_char(options, optopt);
+  optind++;
+  if (!spec) return '?';
+  if (spec[1] == ':') {
+    if (arg[2]) optarg = (char *)arg + 2;
+    else if (optind < argc) optarg = argv[optind++];
+    else return options && options[0] == ':' ? ':' : '?';
+  }
+  return optopt;
+}

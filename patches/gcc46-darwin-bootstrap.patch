+BEGIN {
+  print "/* Generated by bootstrap-genconstants.awk.  */"
+  print "#ifndef GCC_INSN_CONSTANTS_H"
+  print "#define GCC_INSN_CONSTANTS_H"
+  print ""
+}
+
+function strip_comments(line) {
+  sub(/;.*/, "", line)
+  sub(/\/\*.*/, "", line)
+  return line
+}
+
+function start_enum(line, md_enum) {
+  enum_name = line
+  sub(/^[^"]*"/, "", enum_name)
+  sub(/".*$/, "", enum_name)
+  enum_md = md_enum
+  enum_count = 0
+  enum_open = 1
+  print ""
+  print "enum " enum_name " {"
+}
+
+function emit_enum_value(name) {
+  if (name == "")
+    return
+  if (enum_count)
+    print ","
+  if (enum_md)
+    value_name = toupper(enum_name "_" name)
+  else
+    value_name = name
+  printf "  %s = %d", value_name, enum_count
+  enum_count++
+}
+
+function finish_enum() {
+  print ""
+  print "};"
+  macro = toupper("num_" enum_name "_values")
+  print "#define " macro " " enum_count
+  print "extern const char *const " enum_name "_strings[];"
+  enum_open = 0
+}
+
+function scan_constants(line, rest) {
+  rest = line
+  while (match(rest, /\([A-Za-z_][A-Za-z0-9_]*[ \t]+[-+xXa-fA-F0-9]+\)/)) {
+    pair = substr(rest, RSTART + 1, RLENGTH - 2)
+    name = pair
+    sub(/[ \t].*$/, "", name)
+    value = pair
+    sub(/^[^ \t]+[ \t]+/, "", value)
+    print "#define " name " " value
+    rest = substr(rest, RSTART + RLENGTH)
+  }
+}
+
+{
+  line = strip_comments($0)
+  if (enum_open) {
+    done = index(line, "]")
+    if (done)
+      line = substr(line, 1, done - 1)
+    gsub(/[()\[]/, " ", line)
+    n = split(line, parts, /[ \t\r\n]+/)
+    for (i = 1; i <= n; i++)
+      if (parts[i] ~ /^[A-Za-z_][A-Za-z0-9_]*$/)
+        emit_enum_value(parts[i])
+    if (done)
+      finish_enum()
+  } else if (line ~ /\(define_c_enum[ \t]+"/) {
+    start_enum(line, 0)
+  } else if (line ~ /\(define_enum[ \t]+"/) {
+    start_enum(line, 1)
+  } else if (line ~ /\(define_constants/) {
+    constants_open = 1
+  } else if (constants_open) {
+    scan_constants(line)
+    if (line ~ /\]/)
+      constants_open = 0
+  }
+}
+
+END {
+  print ""
+  print "#endif /* GCC_INSN_CONSTANTS_H */"
+}

:DATA_msg_short_read
	"elf64-to-m1: short read on ELF header"

## ELF64 header buffer (64 bytes)
:BUFFER_elf_header
	%0x00000000 %0x00000000 %0x00000000 %0x00000000
	%0x00000000 %0x00000000 %0x00000000 %0x00000000
	%0x00000000 %0x00000000 %0x00000000 %0x00000000
	%0x00000000 %0x00000000 %0x00000000 %0x00000000

## Globals — bump-allocated working memory pointer + cursor
:GLOBAL_BASE
	%0x00000000 %0x00000000

:GLOBAL_INPUT_FD
	%0x00000000

:GLOBAL_INPUT_PATH_PTR
	%0x00000000 %0x00000000

:GLOBAL_OUTPUT_PATH_PTR
	%0x00000000 %0x00000000

:GLOBAL_PREFIX_PTR
	%0x00000000 %0x00000000

:GLOBAL_SYMBOLS_MODE
	%0x00000000

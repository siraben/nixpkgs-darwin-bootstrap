:DATA_section_markers
	;; M1 string literals are NUL-terminated, so emit explicit bytes to
	;; keep the markers on their own lines (no NUL between segments).
	;; Total: 1 + 9 + 1 + 10 + 2 = 23 bytes ("\n:ELF_data\n:HEX2_data\n\n").
	!0x0a
	!0x3a !0x45 !0x4c !0x46 !0x5f !0x64 !0x61 !0x74 !0x61
	!0x0a
	!0x3a !0x48 !0x45 !0x58 !0x32 !0x5f !0x64 !0x61 !0x74 !0x61
	!0x0a !0x0a


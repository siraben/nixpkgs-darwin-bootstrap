:DATA_op_488d05
	BYTE_48 BYTE_8D BYTE_05                       ; lea rax, [rip+disp32]

## Opcode table — 32 entries × 4 bytes each (3-byte opcodes use bytes
## [0..2] + 1 zero pad; 2-byte opcodes use bytes [2..3] + 2 zero pads).
## Order matches tools/phase5-amd64-m2.py's patch_binary opcode list.
:DATA_opcode_table
	BYTE_48 BYTE_8D BYTE_05 BYTE_00   ; lea rax, [rip+disp]
	BYTE_48 BYTE_8D BYTE_1D BYTE_00   ; lea rbx
	BYTE_48 BYTE_8D BYTE_0D BYTE_00   ; lea rcx
	BYTE_48 BYTE_8D BYTE_15 BYTE_00   ; lea rdx
	BYTE_48 BYTE_8D BYTE_35 BYTE_00   ; lea rsi
	BYTE_48 BYTE_8D BYTE_3D BYTE_00   ; lea rdi
	BYTE_4C BYTE_8D BYTE_05 BYTE_00   ; lea r8
	BYTE_4C BYTE_8D BYTE_0D BYTE_00   ; lea r9
	BYTE_4C BYTE_8D BYTE_15 BYTE_00   ; lea r10
	BYTE_4C BYTE_8D BYTE_1D BYTE_00   ; lea r11
	BYTE_48 BYTE_8B BYTE_05 BYTE_00   ; mov rax, [rip+disp]
	BYTE_48 BYTE_8B BYTE_1D BYTE_00   ; mov rbx
	BYTE_48 BYTE_8B BYTE_0D BYTE_00   ; mov rcx
	BYTE_48 BYTE_8B BYTE_15 BYTE_00   ; mov rdx
	BYTE_48 BYTE_8B BYTE_35 BYTE_00   ; mov rsi
	BYTE_48 BYTE_8B BYTE_3D BYTE_00   ; mov rdi
	BYTE_4C BYTE_8B BYTE_05 BYTE_00   ; mov r8
	BYTE_4C BYTE_8B BYTE_0D BYTE_00   ; mov r9
	BYTE_4C BYTE_8B BYTE_15 BYTE_00   ; mov r10
	BYTE_4C BYTE_8B BYTE_1D BYTE_00   ; mov r11
	BYTE_48 BYTE_89 BYTE_05 BYTE_00   ; mov [rip+disp], rax
	BYTE_48 BYTE_89 BYTE_1D BYTE_00   ; mov [rip+disp], rbx
	BYTE_48 BYTE_89 BYTE_0D BYTE_00   ; mov [rip+disp], rcx
	BYTE_48 BYTE_89 BYTE_15 BYTE_00   ; mov [rip+disp], rdx
	BYTE_48 BYTE_89 BYTE_35 BYTE_00   ; mov [rip+disp], rsi
	BYTE_48 BYTE_89 BYTE_3D BYTE_00   ; mov [rip+disp], rdi
	BYTE_4C BYTE_89 BYTE_05 BYTE_00   ; mov [rip+disp], r8
	BYTE_4C BYTE_89 BYTE_0D BYTE_00   ; mov [rip+disp], r9
	BYTE_4C BYTE_89 BYTE_15 BYTE_00   ; mov [rip+disp], r10
	BYTE_4C BYTE_89 BYTE_1D BYTE_00   ; mov [rip+disp], r11
	BYTE_00 BYTE_00 BYTE_88 BYTE_05   ; mov [rip+disp], al  (2-byte: bytes [2..3])
	BYTE_00 BYTE_00 BYTE_8A BYTE_05   ; mov al, [rip+disp]  (2-byte: bytes [2..3])

:DATA_opcode_lens
	BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03
	BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03
	BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03 BYTE_03
	BYTE_02 BYTE_02
